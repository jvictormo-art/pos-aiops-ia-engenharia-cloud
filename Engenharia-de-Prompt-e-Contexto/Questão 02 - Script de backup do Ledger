#!/usr/bin/env bash
# =============================================================================
# ledger_backup.sh — Automated PostgreSQL backup for ledger_prod
#
# Autor:      DBRE / HVT Infrastructure
# Versão:     1.0.0
# Ambiente:   Ubuntu 22.04 LTS — ledger-db.internal.hvt.io
# Descrição:  Realiza dump do banco ledger_prod, compacta com gzip, envia ao
#             S3 (hvt-ledger-backups), aplica retenção de 30 dias e registra
#             cada execução em /var/log/ledger-backup.log.
#
# Pré-requisitos:
#   - postgresql-client instalado   (pg_dump)
#   - awscli v2 instalado           (aws s3 cp / aws s3 ls / aws s3 rm)
#   - IAM Role com permissões:      s3:PutObject, s3:GetObject,
#                                   s3:ListBucket, s3:DeleteObject
#   - Variável PGPASSWORD populada  pelo AWS Secrets Manager via IAM Role
#
# Uso:  sudo -u backup_user /opt/scripts/ledger_backup.sh
# Cron: 0 2 * * *  backup_user  /opt/scripts/ledger_backup.sh
# =============================================================================

set -euo pipefail
IFS=$'\n\t'

# ---------------------------------------------------------------------------
# 1. CONSTANTES E CONFIGURAÇÕES
# ---------------------------------------------------------------------------
readonly DB_HOST="ledger-db.internal.hvt.io"
readonly DB_PORT="5432"
readonly DB_NAME="ledger_prod"
readonly DB_USER="backup_user"

readonly AWS_REGION="us-east-1"
readonly S3_BUCKET="hvt-ledger-backups"
readonly S3_PREFIX="postgresql/${DB_NAME}"      # pasta lógica dentro do bucket
readonly RETENTION_DAYS=30

readonly WORK_DIR="/var/backups/ledger"
readonly LOG_FILE="/var/log/ledger-backup.log"
readonly LOCK_FILE="/var/run/ledger-backup.lock"

readonly TIMESTAMP="$(date -u '+%Y%m%dT%H%M%SZ')"
readonly DUMP_BASE="ledger_prod_${TIMESTAMP}"
readonly DUMP_FILE="${WORK_DIR}/${DUMP_BASE}.dump"
readonly DUMP_GZ="${DUMP_FILE}.gz"
readonly S3_KEY="${S3_PREFIX}/${DUMP_BASE}.dump.gz"

readonly MIN_FREE_GB=20          # aborta se espaço livre for menor que este valor
readonly DUMP_TIMEOUT=14400      # segundos (4 h) — limite para o pg_dump

# ---------------------------------------------------------------------------
# 2. FUNÇÕES UTILITÁRIAS
# ---------------------------------------------------------------------------

# log <nível> <mensagem>
log() {
    local level="$1"
    shift
    local message="$*"
    local ts
    ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf '[%s] [%-5s] %s\n' "${ts}" "${level}" "${message}" | tee -a "${LOG_FILE}"
}

log_info()  { log "INFO"  "$@"; }
log_warn()  { log "WARN"  "$@"; }
log_error() { log "ERROR" "$@"; }

# Limpeza garantida ao sair (EXIT trap)
cleanup() {
    local exit_code=$?

    # Remove arquivo de dump não compactado se ainda existir
    [[ -f "${DUMP_FILE}" ]] && rm -f "${DUMP_FILE}" \
        && log_info "Arquivo temporário de dump removido: ${DUMP_FILE}"

    # Remove dump compactado apenas em caso de falha (não queremos apagar o artefato final)
    if [[ ${exit_code} -ne 0 ]]; then
        [[ -f "${DUMP_GZ}" ]] && rm -f "${DUMP_GZ}" \
            && log_warn "Dump compactado removido por falha: ${DUMP_GZ}"
        log_error "Backup FINALIZADO COM FALHA — exit_code=${exit_code}"
    else
        log_info "Backup FINALIZADO COM SUCESSO."
    fi

    # Remove lock file
    [[ -f "${LOCK_FILE}" ]] && rm -f "${LOCK_FILE}"
}
trap cleanup EXIT

# Encerra o script com código de erro e loga a causa
die() {
    log_error "$*"
    exit 1
}

# ---------------------------------------------------------------------------
# 3. VERIFICAÇÕES PRÉ-EXECUÇÃO
# ---------------------------------------------------------------------------

preflight_checks() {
    log_info "==== Iniciando backup: ${DB_NAME} @ ${TIMESTAMP} ===="

    # 3.1 Lock para evitar execuções simultâneas
    if [[ -f "${LOCK_FILE}" ]]; then
        local existing_pid
        existing_pid="$(cat "${LOCK_FILE}")"
        if kill -0 "${existing_pid}" 2>/dev/null; then
            die "Outra instância do backup está em execução (PID ${existing_pid}). Abortando."
        else
            log_warn "Lock obsoleto encontrado (PID ${existing_pid} não existe). Removendo."
            rm -f "${LOCK_FILE}"
        fi
    fi
    echo "$$" > "${LOCK_FILE}"
    log_info "Lock adquirido (PID $$)."

    # 3.2 Dependências obrigatórias
    local deps=("pg_dump" "gzip" "aws" "df" "date" "sha256sum")
    for dep in "${deps[@]}"; do
        command -v "${dep}" &>/dev/null \
            || die "Dependência não encontrada: '${dep}'. Instale antes de continuar."
    done
    log_info "Dependências verificadas: ${deps[*]}"

    # 3.3 Variável PGPASSWORD — deve ser injetada pelo Secrets Manager
    [[ -n "${PGPASSWORD:-}" ]] \
        || die "Variável PGPASSWORD não definida. Verifique a integração com o AWS Secrets Manager."

    # 3.4 Diretório de trabalho
    [[ -d "${WORK_DIR}" ]] \
        || die "Diretório de trabalho inexistente: ${WORK_DIR}"

    # 3.5 Permissão de escrita no diretório de trabalho
    [[ -w "${WORK_DIR}" ]] \
        || die "Sem permissão de escrita em ${WORK_DIR}."

    # 3.6 Espaço em disco
    local free_gb
    free_gb=$(df -BG --output=avail "${WORK_DIR}" | tail -1 | tr -d 'G ')
    log_info "Espaço livre em ${WORK_DIR}: ${free_gb} GB"
    (( free_gb >= MIN_FREE_GB )) \
        || die "Espaço insuficiente em disco: ${free_gb} GB disponíveis (mínimo: ${MIN_FREE_GB} GB)."

    # 3.7 Permissão de escrita no arquivo de log
    touch "${LOG_FILE}" 2>/dev/null \
        || die "Sem permissão para escrever em ${LOG_FILE}."

    # 3.8 Conectividade com o banco
    log_info "Testando conectividade com ${DB_HOST}:${DB_PORT}..."
    PGCONNECT_TIMEOUT=10 pg_isready \
        --host="${DB_HOST}" \
        --port="${DB_PORT}" \
        --username="${DB_USER}" \
        --dbname="${DB_NAME}" \
        --quiet \
        || die "Banco de dados não está acessível em ${DB_HOST}:${DB_PORT}."
    log_info "Banco de dados acessível."

    # 3.9 Credenciais AWS / permissão S3 (GetBucketLocation como smoke test leve)
    log_info "Verificando acesso ao S3 bucket: ${S3_BUCKET}..."
    aws s3api get-bucket-location \
        --bucket "${S3_BUCKET}" \
        --region "${AWS_REGION}" \
        --output text &>/dev/null \
        || die "Sem acesso ao bucket S3 '${S3_BUCKET}'. Verifique a IAM Role da instância."
    log_info "Acesso ao S3 confirmado."
}

# ---------------------------------------------------------------------------
# 4. DUMP DO BANCO DE DADOS
# ---------------------------------------------------------------------------

run_dump() {
    log_info "Iniciando pg_dump (formato custom, compressão 0 — gzip externo)..."
    log_info "Destino temporário: ${DUMP_FILE}"

    # Formato -Fc (custom) permite restauração paralela e seletiva.
    # --compress=0 evita dupla compressão (gzip virá na etapa seguinte).
    # --no-password garante que nunca abrirá um prompt interativo.
    # timeout mata o processo se ultrapassar DUMP_TIMEOUT segundos.
    timeout "${DUMP_TIMEOUT}" pg_dump \
        --host="${DB_HOST}" \
        --port="${DB_PORT}" \
        --username="${DB_USER}" \
        --dbname="${DB_NAME}" \
        --format=custom \
        --compress=0 \
        --no-password \
        --file="${DUMP_FILE}" \
        --verbose 2>> "${LOG_FILE}" \
        || die "pg_dump falhou ou ultrapassou o timeout de ${DUMP_TIMEOUT}s."

    # Valida que o arquivo foi criado e tem tamanho razoável
    [[ -s "${DUMP_FILE}" ]] \
        || die "Arquivo de dump está vazio após pg_dump."

    local dump_size
    dump_size=$(du -sh "${DUMP_FILE}" | cut -f1)
    log_info "pg_dump concluído. Tamanho: ${dump_size}"
}

# ---------------------------------------------------------------------------
# 5. COMPACTAÇÃO COM GZIP
# ---------------------------------------------------------------------------

compress_dump() {
    log_info "Compactando com gzip (-6) → ${DUMP_GZ}..."

    # -6: equilíbrio entre velocidade e taxa de compressão
    # --keep: mantém o original (será removido pelo cleanup após verificação)
    gzip -6 --keep --stdout "${DUMP_FILE}" > "${DUMP_GZ}" \
        || die "Falha na compactação com gzip."

    # Remove o dump não compactado assim que o .gz for gerado com sucesso
    rm -f "${DUMP_FILE}"
    log_info "Dump original removido após compactação bem-sucedida."

    local gz_size
    gz_size=$(du -sh "${DUMP_GZ}" | cut -f1)
    log_info "Compactação concluída. Tamanho: ${gz_size}"

    # Gera checksum SHA-256 para auditoria/integridade
    local checksum_file="${DUMP_GZ}.sha256"
    sha256sum "${DUMP_GZ}" | awk '{print $1}' > "${checksum_file}"
    local checksum
    checksum=$(cat "${checksum_file}")
    log_info "SHA-256: ${checksum}"
}

# ---------------------------------------------------------------------------
# 6. UPLOAD PARA O S3
# ---------------------------------------------------------------------------

upload_to_s3() {
    local s3_uri="s3://${S3_BUCKET}/${S3_KEY}"
    log_info "Iniciando upload para S3: ${s3_uri}..."

    # --sse aws:kms: Server-Side Encryption com chave gerenciada pelo KMS
    # --storage-class STANDARD_IA: mais barato para backups com acesso infrequente
    # --expected-size: permite multipart upload automático (recomendado para >8 GB)
    aws s3 cp "${DUMP_GZ}" "${s3_uri}" \
        --region "${AWS_REGION}" \
        --sse aws:kms \
        --storage-class STANDARD_IA \
        --expected-size "$(stat -c%s "${DUMP_GZ}")" \
        --no-progress \
        2>> "${LOG_FILE}" \
        || die "Falha no upload para S3: ${s3_uri}"

    log_info "Upload concluído: ${s3_uri}"

    # Faz upload do checksum junto
    aws s3 cp "${DUMP_GZ}.sha256" "${s3_uri}.sha256" \
        --region "${AWS_REGION}" \
        --sse aws:kms \
        --no-progress \
        2>> "${LOG_FILE}" \
        || log_warn "Falha no upload do checksum SHA-256 (não-crítico)."

    # Verifica que o objeto chegou ao S3 (head-object)
    aws s3api head-object \
        --bucket "${S3_BUCKET}" \
        --key "${S3_KEY}" \
        --region "${AWS_REGION}" \
        --output text &>/dev/null \
        || die "Verificação pós-upload falhou: objeto não encontrado no S3."

    log_info "Integridade do upload verificada no S3."

    # Remove dump compactado local após upload verificado
    rm -f "${DUMP_GZ}" "${DUMP_GZ}.sha256"
    log_info "Arquivos locais removidos após upload bem-sucedido."
}

# ---------------------------------------------------------------------------
# 7. APLICAR RETENÇÃO DE 30 DIAS NO S3
# ---------------------------------------------------------------------------

apply_retention() {
    log_info "Aplicando política de retenção: removendo backups com mais de ${RETENTION_DAYS} dias..."

    # Data de corte em formato ISO 8601 UTC
    local cutoff_date
    cutoff_date=$(date -u -d "${RETENTION_DAYS} days ago" '+%Y-%m-%dT%H:%M:%SZ')
    log_info "Data de corte: ${cutoff_date}"

    # Lista todos os objetos do prefixo e filtra os mais antigos que a data de corte
    local old_keys
    old_keys=$(
        aws s3api list-objects-v2 \
            --bucket "${S3_BUCKET}" \
            --prefix "${S3_PREFIX}/" \
            --region "${AWS_REGION}" \
            --query "Contents[?LastModified<='${cutoff_date}'].Key" \
            --output text 2>> "${LOG_FILE}"
    ) || { log_warn "Falha ao listar objetos para retenção. Retenção não aplicada."; return 0; }

    if [[ -z "${old_keys}" || "${old_keys}" == "None" ]]; then
        log_info "Nenhum backup elegível para remoção."
        return 0
    fi

    local removed=0
    local failed=0

    while IFS= read -r key; do
        [[ -z "${key}" ]] && continue
        log_info "Removendo objeto expirado: s3://${S3_BUCKET}/${key}"
        if aws s3 rm "s3://${S3_BUCKET}/${key}" \
            --region "${AWS_REGION}" \
            2>> "${LOG_FILE}"; then
            (( removed++ )) || true
        else
            log_warn "Falha ao remover: ${key}"
            (( failed++ )) || true
        fi
    done <<< "${old_keys}"

    log_info "Retenção aplicada — removidos: ${removed} | falhas: ${failed}"
    (( failed > 0 )) && log_warn "Alguns objetos não foram removidos. Verifique permissões s3:DeleteObject."

    return 0
}

# ---------------------------------------------------------------------------
# 8. RESUMO FINAL
# ---------------------------------------------------------------------------

log_summary() {
    local end_ts
    end_ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    log_info "==== Resumo do backup ===="
    log_info "  Banco         : ${DB_NAME} @ ${DB_HOST}:${DB_PORT}"
    log_info "  S3 destino    : s3://${S3_BUCKET}/${S3_KEY}"
    log_info "  Retenção      : ${RETENTION_DAYS} dias"
    log_info "  Fim execução  : ${end_ts}"
    log_info "=========================="
}

# ---------------------------------------------------------------------------
# 9. PONTO DE ENTRADA
# ---------------------------------------------------------------------------

main() {
    preflight_checks
    run_dump
    compress_dump
    upload_to_s3
    apply_retention
    log_summary
}

main "$@"


Justificativa: A Role define a persona com expertise técnica em banco de dados e cloud, a Task detalha a ação específica de automatizar a rotina de backup e o Format define o script bash como output esperado.




